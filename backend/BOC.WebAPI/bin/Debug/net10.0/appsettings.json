{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Quartz": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1,1433;Database=BOC_Research_Evaluation_2026;User ID=sa;Password=12345;TrustServerCertificate=true;Column Encryption Setting=enabled;MultipleActiveResultSets=true;Encrypt=false;"
  },

  "Jwt": {
    "Issuer": "BOC.ResearchSystem",
    "Audience": "BOC.ResearchSystem.Client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7,
    "PrivateKeyPath": "keys/private.pem",
    "PublicKeyPath": "keys/public.pem",
    "SecurityKey": "BOC_Research_Evaluation_2026_SuperSecretKey_ChangeInProduction_MinLength32Chars!"
  },

  "Smtp": {
    "Host": "mail.boc.oil.gov.iq",
    "Port": 465,
    "UseSsl": true,
    "FromEmail": "hr-planing@boc.oil.gov.iq",
    "FromDisplayName": "BOC HR Research Planning",
    "Password": "Sab@72834",
    "TimeoutSeconds": 30
  },

  "Ftp": {
    "Host": "172.18.8.23",
    "Port": 21,
    "Username": "user9",
    "Password": "hrpg9",
    "RootDirectory": "/uploads/boc-research",
    "UseSftp": false,
    "TimeoutSeconds": 60,
    "EnableSsl": false
  },

  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000",
    "InstanceName": "BOC_Research_",
    "DefaultExpiryMinutes": 60
  },

  "SignalR": {
    "RedisBackplane": "localhost:6379,abortConnect=false",
    "EnableDetailedErrors": false
  },

  "CorsPolicy": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://research.boc.oil.gov.iq"
    ]
  },

  "RateLimit": {
    "LoginMaxAttempts": 5,
    "LoginWindowMinutes": 15,
    "ApiMaxCallsPerMinute": 100
  },

  "FileUpload": {
    "MaxFileSizeMB": 50,
    "AllowedExtensions": [ ".pdf", ".doc", ".docx", ".xlsx", ".png", ".jpg" ],
    "AllowedMimeTypes": [
      "application/pdf",
      "application/msword",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "image/png",
      "image/jpeg"
    ],
    "FileAccessTokenExpiryHours": 24,
    "EnableAntivirusScan": false
  },

  "Sla": {
    "DefaultEvaluationDays": 14,
    "WarningThresholdDays": 10,
    "PlagiarismLockoutMonths": 3
  },

  "Quartz": {
    "UsePersistentStore": false,
    "DataSource": "BOC_Research_Evaluation_2026",
    "TablePrefix": "QRTZ_"
  },

  "Hangfire": {
    "DashboardPath": "/hangfire",
    "WorkerCount": 5,
    "RetryAttempts": 5
  },

  "TwoFactor": {
    "Issuer": "BOC Research System",
    "RequiredForRoles": [ "Admin", "Chairman", "Deputy", "Secretary" ]
  },

  "HealthChecks": {
    "SqlServerEnabled": true,
    "RedisEnabled": true,
    "FtpEnabled": false,
    "SmtpEnabled": false
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/boc-research-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {CorrelationId} {UserId} {EmployeeID} {Role} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
