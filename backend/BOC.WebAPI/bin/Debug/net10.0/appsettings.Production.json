{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error",
      "Microsoft.EntityFrameworkCore.Database.Command": "Error",
      "Quartz": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "REPLACE_WITH_PRODUCTION_CONNECTION_STRING_FROM_SECRETS_MANAGER"
  },

  "Jwt": {
    "Issuer": "BOC.ResearchSystem",
    "Audience": "BOC.ResearchSystem.Client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7,
    "PrivateKeyPath": "REPLACE_WITH_SECRET",
    "PublicKeyPath": "REPLACE_WITH_SECRET",
    "SecurityKey": "REPLACE_WITH_PRODUCTION_SECRET_MIN_32_CHARS"
  },

  "Smtp": {
    "Host": "mail.boc.oil.gov.iq",
    "Port": 465,
    "UseSsl": true,
    "FromEmail": "hr-planing@boc.oil.gov.iq",
    "FromDisplayName": "BOC HR Research Planning",
    "Password": "REPLACE_WITH_SMTP_PASSWORD",
    "TimeoutSeconds": 30
  },

  "Ftp": {
    "Host": "REPLACE_WITH_FTP_HOST",
    "Port": 21,
    "Username": "REPLACE_WITH_FTP_USERNAME",
    "Password": "REPLACE_WITH_FTP_PASSWORD",
    "RootDirectory": "/uploads/boc-research",
    "UseSftp": false,
    "TimeoutSeconds": 60,
    "EnableSsl": true
  },

  "Redis": {
    "ConnectionString": "REPLACE_WITH_PRODUCTION_REDIS_CONNECTION_STRING",
    "InstanceName": "BOC_Research_",
    "DefaultExpiryMinutes": 60
  },

  "SignalR": {
    "RedisBackplane": "REPLACE_WITH_PRODUCTION_REDIS_CONNECTION_STRING",
    "EnableDetailedErrors": false
  },

  "CorsPolicy": {
    "AllowedOrigins": [
      "https://research.boc.oil.gov.iq"
    ]
  },

  "RateLimit": {
    "LoginMaxAttempts": 5,
    "LoginWindowMinutes": 15,
    "ApiMaxCallsPerMinute": 100
  },

  "FileUpload": {
    "MaxFileSizeMB": 50,
    "AllowedExtensions": [ ".pdf", ".doc", ".docx", ".xlsx", ".png", ".jpg" ],
    "AllowedMimeTypes": [
      "application/pdf",
      "application/msword",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "image/png",
      "image/jpeg"
    ],
    "FileAccessTokenExpiryHours": 24,
    "EnableAntivirusScan": true
  },

  "HealthChecks": {
    "SqlServerEnabled": true,
    "RedisEnabled": true,
    "FtpEnabled": true,
    "SmtpEnabled": true
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "System": "Error",
        "Microsoft.EntityFrameworkCore": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/prod/boc-research-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 90,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {CorrelationId} {UserId} {EmployeeID} {Role} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
