{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "Quartz": "Information"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1,1433;Database=BOC_Research_Evaluation;User ID=sa;Password=12345;TrustServerCertificate=true;Column Encryption Setting=enabled;MultipleActiveResultSets=true;Encrypt=false;"
  },

  "Jwt": {
    "Issuer": "BOC.ResearchSystem",
    "Audience": "BOC.ResearchSystem.Client",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30,
    "SecurityKey": "BOC_Research_Evaluation_2026_SuperSecretKey_ChangeInProduction_MinLength32Chars!"
  },

  "Smtp": {
    "Host": "mail.boc.oil.gov.iq",
    "Port": 465,
    "UseSsl": true,
    "FromEmail": "hr-planing@boc.oil.gov.iq",
    "FromDisplayName": "BOC HR Research Planning [DEV]",
    "Password": "Sab@72834",
    "TimeoutSeconds": 30
  },

  "Ftp": {
    "Host": "172.18.8.23",
    "Port": 21,
    "Username": "user9",
    "Password": "hrpg9",
    "RootDirectory": "/uploads/boc-research-dev",
    "UseSftp": false,
    "TimeoutSeconds": 60,
    "EnableSsl": false
  },

  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000",
    "InstanceName": "BOC_Dev_",
    "DefaultExpiryMinutes": 120
  },

  "SignalR": {
    "RedisBackplane": "localhost:6379,abortConnect=false",
    "EnableDetailedErrors": true
  },

  "CorsPolicy": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:3000"
    ]
  },

  "RateLimit": {
    "LoginMaxAttempts": 20,
    "LoginWindowMinutes": 5,
    "ApiMaxCallsPerMinute": 1000
  },

  "FileUpload": {
    "MaxFileSizeMB": 50,
    "AllowedExtensions": [ ".pdf", ".doc", ".docx", ".xlsx", ".png", ".jpg" ],
    "AllowedMimeTypes": [
      "application/pdf",
      "application/msword",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "image/png",
      "image/jpeg"
    ],
    "FileAccessTokenExpiryHours": 24,
    "EnableAntivirusScan": false
  },

  "HealthChecks": {
    "SqlServerEnabled": true,
    "RedisEnabled": true,
    "FtpEnabled": false,
    "SmtpEnabled": false
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dev/boc-research-dev-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
